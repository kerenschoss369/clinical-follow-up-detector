# Root environment variable reference
#
# Copy each section into the matching service directory as a local .env file.
# Never commit real .env files or API keys.

# ---------------------------------------------------------------------------
# Node API — copy to apps/api/.env
# ---------------------------------------------------------------------------

# HTTP port for the Express API (default: 3000)
PORT=

# Base URL of the Python AI service (default: http://localhost:8000)
AI_SERVICE_URL=

# Maximum note length in characters (default: 20000)
MAX_NOTE_LENGTH=

# Optional ISO date (YYYY-MM-DD) used when resolving relative deadlines.
# When unset, the API uses today's date.
REFERENCE_DATE=

# Timeout in milliseconds when calling the Python AI service (default: 30000)
AI_SERVICE_TIMEOUT_MS=

# SQLite database file path (default: data/app.db)
DATABASE_PATH=

# ---------------------------------------------------------------------------
# Python AI service — copy to apps/ai-service/.env
# ---------------------------------------------------------------------------

# Required. OpenAI API key.
LLM_API_KEY=

# Required. Model name (for example gpt-4o-mini).
LLM_MODEL=

# LLM request timeout in seconds (default: 30)
LLM_TIMEOUT_SECONDS=

# ---------------------------------------------------------------------------
# React frontend — apps/web
# ---------------------------------------------------------------------------
# No environment variables are required.
# Vite proxies /api to http://localhost:3000 during local development.
